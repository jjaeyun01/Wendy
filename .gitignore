# Python cache
__pycache__/
*.py[cod]
*.pyo

# Vosk speech models (large, download separately)
vosk-model-*/

# ML training data (user-specific, record with ml/collect.py)
ml/data/

# Trained model weights (large binary, regenerate with ml/train.py)
ml/models/*.pt

# DTW gesture templates (user-specific, record with triggers/dtw.py)
triggers/templates/*.json

# macOS
.DS_Store

# Logs
*.log
wendy.err.log
