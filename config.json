{
    "version": "1.0.0",
    "settings": {
      "clap_threshold": 0.1,
      "clap_interval_ms": 800,
      "camera_index": 0,
      "cooldown_ms": 2000
    },
    "profiles": [
      {
        "id": "dev-mode",
        "name": "dev",
        "workspace": "1",
        "icon": "💻",
        "layout": {
          "description": "left: Cursor | right-top: Terminal | right-bottom: Finder",
          "commands": [
            "workspace 1",
            "exec-and-forget open -n /Applications/Cursor.app",
            "exec-and-forget open -n /System/Applications/Utilities/Terminal.app",
            "exec-and-forget open -n /System/Library/CoreServices/Finder.app"
          ],
          "arrange": [
            "focus --app-bundle-id com.todesktop.230313mzl4w4u92",
            "layout h_tiles",
            "focus --app-bundle-id com.apple.Terminal",
            "join-with right",
            "focus --app-bundle-id com.apple.finder",
            "join-with down"
          ]
        }
      },
      {
        "id": "comms-mode",
        "name": "comms",
        "workspace": "2",
        "icon": "💬",
        "layout": {
          "description": "left: Slack | right: Mail",
          "commands": [
            "workspace 2",
            "exec-and-forget open -n /Applications/Slack.app",
            "exec-and-forget open -n /System/Applications/Mail.app"
          ],
          "arrange": [
            "layout h_tiles"
          ]
        }
      },
      {
        "id": "jarvis-mode",
        "name": "jarvis mode",
        "workspace": "9",
        "icon": "🔴",
        "layout": {
          "description": "jarvis theme music",
          "commands": [
            "workspace 9"
          ],
          "arrange": []
        },
        "music": {
          "path": "/Users/music/ironman.mp3"
        }
      }
    ],
    "trigger": {
      "type": "double_clap",
      "target_profile": "dev-mode"
    }
  }